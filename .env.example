PORT=8000
NODE_ENV=production

# API de destino (SPREAD)
SPREAD_API_BASE_URL=https://gogreen.ci.com.br/api
SPREAD_API_TOKEN=REPLACE_WITH_SPREAD_API_TOKEN

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=REPLACE_WITH_TURNSTILE_SITE_KEY
TURNSTILE_SECRET_KEY=REPLACE_WITH_TURNSTILE_SECRET_KEY
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
TURNSTILE_FAIL_OPEN=true

# Segurança do formulário
FORM_MIN_SUBMIT_TIME_MS=3000
FORM_RATE_LIMIT_WINDOW_MS=600000
FORM_RATE_LIMIT_MAX_ATTEMPTS=5

# Google Tag Manager
GTM_ID=GTM-WVSTCSVV

# Meta (Facebook/Instagram)
META_PIXEL_ID=679288165070208
META_CAPI_TOKEN=
# Leave META_CAPI_TOKEN empty to disable server-side CAPI
