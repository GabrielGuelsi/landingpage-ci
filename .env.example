PORT=8000
NODE_ENV=production

# API de destino (SPREAD)
SPREAD_API_BASE_URL=https://gogreen.ci.com.br/api
SPREAD_API_TOKEN=REPLACE_WITH_SPREAD_API_TOKEN

# Meta WhatsApp Cloud API (envio automatico apos lead com sucesso)
WHATSAPP_TEST_MODE=false
WHATSAPP_API_VERSION=v23.0
WHATSAPP_ACCESS_TOKEN=REPLACE_WITH_META_SYSTEM_USER_TOKEN
WHATSAPP_PHONE_NUMBER_ID=REPLACE_WITH_PHONE_NUMBER_ID
WHATSAPP_TEMPLATE_NAME=ci_ireland_lead_autoreply
WHATSAPP_TEMPLATE_USES_NAME_PARAM=true
WHATSAPP_TEMPLATE_LANG_PT=pt_BR
WHATSAPP_TEMPLATE_LANG_EN=en
WHATSAPP_TEMPLATE_LANG_ES=es

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=REPLACE_WITH_TURNSTILE_SITE_KEY
TURNSTILE_SECRET_KEY=REPLACE_WITH_TURNSTILE_SECRET_KEY
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
TURNSTILE_FAIL_OPEN=true

# Segurança do formulário
FORM_MIN_SUBMIT_TIME_MS=3000
FORM_RATE_LIMIT_WINDOW_MS=600000
FORM_RATE_LIMIT_MAX_ATTEMPTS=5
